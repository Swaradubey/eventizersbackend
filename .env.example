# Database connection strings (PostgreSQL/Neon)
# DATABASE_URL is for connection pooling at runtime, DIRECT_URL is for direct schema migrations
DATABASE_URL=
DIRECT_URL=

# Secret key for signing JWT tokens
JWT_SECRET=

# Port number for local Express server
PORT=5000

# Environment mode (production, development)
NODE_ENV=development

# Allowed cross-origin frontend URL (comma-separated if multiple)
FRONTEND_URL=http://localhost:3000

# Google Gemini API key for AI-powered event generation
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model name (default: gemini-2.0-flash)
# Supported models: gemini-2.0-flash, gemini-2.5-flash, gemini-1.5-flash-latest
GEMINI_MODEL=gemini-2.0-flash
# (leaked key removed)
GEMINI_MODEL=gemini-2.0-flash

