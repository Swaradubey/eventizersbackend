// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int           @id @default(autoincrement())
  name         String
  email        String        @unique
  password     String        @map("password_hash")
  phoneNumber  String?       @map("phone_number")
  role         Role          @default(USER)
  createdAt    DateTime      @default(now()) @map("created_at")
  events       Event[]
  ticketOrders TicketOrder[]
  registries   Registry[]
  messages     Message[]
  adminProfile              AdminProfile?
  adminNotificationSettings AdminNotificationSettings?
  adminSecuritySettings     AdminSecuritySettings?
  adminPreferences          AdminPreferences?
  adminTeamMembers          AdminTeamMember[]

  @@map("users")
}

model Event {
  id           String        @id @default(uuid()) @db.Uuid
  title        String
  description  String?
  eventType    String?       @map("event_type")
  venue        String
  address      String?
  city         String?
  state        String?
  country      String?
  eventDate    DateTime      @map("event_date")
  eventTime    DateTime      @map("event_time") @db.Time(6)
  coverImage   String?       @map("cover_image")
  selectedTemplateId String?   @map("selected_template_id")
  status       String        @default("draft")
  createdBy    Int           @map("created_by")
  user         User          @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @default(now()) @map("updated_at")
  invitation   Invitation?
  guests       Guest[]
  ticketTiers  TicketTier[]
  ticketOrders TicketOrder[]
  checkIns       CheckIn[]
  registries     Registry[]
  messages       Message[]
  auditLogs      AuditLog[]
  securityAlerts SecurityAlert[]

  @@map("events")
}

model Invitation {
  id              String   @id @default(cuid())
  eventId         String   @unique @map("event_id") @db.Uuid
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title           String
  subtitle        String?
  mainText        String?  @map("main_text")
  message         String?
  accentColor     String   @default("#5B5FEF") @map("accent_color")
  backgroundColor String   @default("#F6F9FC") @map("background_color")
  textColor       String   @default("#1A1118") @map("text_color")
  titleSize       Int      @default(48) @map("title_size")
  fontWeight      String   @default("normal") @map("font_weight")
  fontFamily      String   @default("sans-serif") @map("font_family")
  textAlignment   String   @default("center") @map("text_alignment")
  imageUrl        String?  @map("image_url")
  buttonText      String   @default("RSVP Now") @map("button_text")
  buttonColor     String   @default("#5B5FEF") @map("button_color")
  buttonRadius    Int      @default(8) @map("button_radius")
  status          String   @default("draft")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("invitations")
}

model Guest {
  id        String    @id @default(uuid()) @db.Uuid
  eventId   String    @map("event_id") @db.Uuid
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  email     String
  phone     String?
  status    String    @default("invited")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  checkIns  CheckIn[]
  messageRecipients MessageRecipient[]
  sentAt      DateTime? @map("sent_at")
  openedAt    DateTime? @map("opened_at")
  clickedAt   DateTime? @map("clicked_at")
  respondedAt DateTime? @map("responded_at")
  rsvpStatus  String?   @map("rsvp_status")

  @@map("guests")
}

enum TicketTierStatus {
  DRAFT
  ACTIVE
  INACTIVE
  SOLD_OUT
  EXPIRED
  ARCHIVED
}

enum TicketOrderStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
  EXPIRED
}

model TicketTier {
  id           String           @id @default(cuid())
  eventId      String           @map("event_id") @db.Uuid
  name         String
  description  String?
  price        Decimal          @db.Decimal(10, 2)
  currency     String           @default("INR")
  capacity     Int
  minPerOrder  Int              @default(1) @map("min_per_order")
  maxPerOrder  Int?             @map("max_per_order")
  salesStartAt DateTime?        @map("sales_start_at")
  salesEndAt   DateTime?        @map("sales_end_at")
  status       TicketTierStatus @default(ACTIVE)
  isActive     Boolean          @default(true) @map("is_active")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  event      Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  orderItems TicketOrderItem[]

  @@index([eventId])
  @@index([eventId, status])
  @@map("ticket_tiers")
}

model TicketOrder {
  id               String            @id @default(cuid())
  eventId          String            @map("event_id") @db.Uuid
  userId           Int?              @map("user_id")
  customerName     String            @map("customer_name")
  customerEmail    String            @map("customer_email")
  status           TicketOrderStatus @default(PENDING)
  subtotal         Decimal           @db.Decimal(10, 2)
  totalAmount      Decimal           @map("total_amount") @db.Decimal(10, 2)
  currency         String            @default("INR")
  paymentReference String?           @map("payment_reference")
  stripeSessionId  String?           @unique @map("stripe_session_id")
  paymentIntentId  String?           @map("payment_intent_id")
  paidAt           DateTime?         @map("paid_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  event Event             @relation(fields: [eventId], references: [id])
  items TicketOrderItem[]
  user  User?             @relation(fields: [userId], references: [id])

  @@index([eventId])
  @@index([status])
  @@index([customerEmail])
  @@map("ticket_orders")
}

model TicketOrderItem {
  id           String   @id @default(cuid())
  orderId      String   @map("order_id")
  ticketTierId String   @map("ticket_tier_id")
  quantity     Int
  unitPrice    Decimal  @map("unit_price") @db.Decimal(10, 2)
  totalPrice   Decimal  @map("total_price") @db.Decimal(10, 2)
  createdAt    DateTime @default(now()) @map("created_at")

  order      TicketOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketTier TicketTier  @relation(fields: [ticketTierId], references: [id])

  @@index([orderId])
  @@index([ticketTierId])
  @@map("ticket_order_items")
}

enum CheckInMethod {
  QR
  MANUAL
}

model CheckIn {
  id            String        @id @default(cuid())
  eventId       String        @map("event_id") @db.Uuid
  guestId       String?       @map("guest_id") @db.Uuid
  ticketId      String?       @map("ticket_id")
  checkedInAt   DateTime      @default(now()) @map("checked_in_at")
  checkedInById String?       @map("checked_in_by_id")
  method        CheckInMethod @default(MANUAL)
  latitude      Decimal?      @db.Decimal(9, 6)
  longitude     Decimal?      @db.Decimal(9, 6)
  deviceInfo    String?       @map("device_info")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  event Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest Guest? @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@unique([eventId, guestId])
  @@unique([eventId, ticketId])
  @@index([eventId])
  @@index([guestId])
  @@index([ticketId])
  @@map("check_ins")
}

enum RegistryType {
  CASH_FUND
  GIFT_REGISTRY
  DONATION
  EXTERNAL_LINK
}

model Registry {
  id               String                 @id @default(cuid())
  eventId          String                 @map("event_id") @db.Uuid
  userId           Int                    @map("user_id")
  type             RegistryType
  title            String
  description      String?
  goalAmount       Decimal?               @map("goal_amount") @db.Decimal(12, 2)
  currentAmount    Decimal                @default(0) @map("current_amount") @db.Decimal(12, 2)
  currency         String                 @default("INR")
  externalUrl      String?                @map("external_url")
  contributorCount Int                    @default(0) @map("contributor_count")
  isActive         Boolean                @default(true) @map("is_active")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")

  event            Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions    RegistryContribution[]

  @@index([eventId])
  @@index([userId])
  @@index([type])
  @@map("registries")
}

model RegistryContribution {
  id               String   @id @default(cuid())
  registryId       String   @map("registry_id")
  contributorId    String?  @map("contributor_id")
  contributorName  String?  @map("contributor_name")
  contributorEmail String?  @map("contributor_email")
  amount           Decimal  @db.Decimal(12, 2)
  message          String?
  createdAt        DateTime @default(now()) @map("created_at")

  registry         Registry @relation(fields: [registryId], references: [id], onDelete: Cascade)

  @@index([registryId])
  @@map("registry_contributions")
}

enum Role {
  USER
  ADMIN
}

enum MessageStatus {
  DRAFT
  SENT
  FAILED
}

enum MessageRecipientType {
  ALL_GUESTS
  ATTENDING
  DECLINED
  PENDING
  SELECTED
}

model Message {
  id              String                 @id @default(cuid())
  subject         String
  body            String
  status          MessageStatus          @default(SENT)
  recipientType   MessageRecipientType   @map("recipient_type")
  senderId        Int                    @map("sender_id")
  eventId         String                 @map("event_id") @db.Uuid
  sentAt          DateTime?              @map("sent_at")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  sender          User                   @relation(fields: [senderId], references: [id], onDelete: Cascade)
  event           Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  recipients      MessageRecipient[]

  @@index([senderId])
  @@index([eventId])
  @@index([status])
  @@index([createdAt])
  @@map("messages")
}

model MessageRecipient {
  id          String    @id @default(cuid())
  messageId   String    @map("message_id")
  guestId     String    @map("guest_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")

  message     Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  guest       Guest     @relation(fields: [guestId], references: [id], onDelete: Cascade)

  @@unique([messageId, guestId])
  @@index([messageId])
  @@index([guestId])
  @@map("message_recipients")
}

model SecurityAlert {
  id          String   @id @default(uuid())
  type        String
  description String
  severity    String
  isResolved  Boolean  @default(false) @map("isResolved")
  createdAt   DateTime @default(now()) @map("createdAt")
  eventId     String   @map("event_id") @db.Uuid
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("SecurityAlert")
}

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  actorEmail String   @map("actorEmail")
  userEmail  String?  @map("userEmail")
  entityType String?  @map("entityType")
  entityId   String?  @map("entityId")
  metadata   Json?    @map("metadata")
  createdAt  DateTime @default(now()) @map("createdAt")
  eventId    String   @map("event_id") @db.Uuid
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("AuditLog")
}

model AdminProfile {
  id           String   @id @default(uuid())
  userId       Int      @unique @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String   @map("full_name")
  email        String
  organization String?
  profileImage String?  @map("profile_image")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admin_profiles")
}

model AdminNotificationSettings {
  id             String   @id @default(uuid())
  userId         Int      @unique @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rsvpResponses  Boolean  @default(true) @map("rsvp_responses")
  eventReminders Boolean  @default(true) @map("event_reminders")
  securityAlerts Boolean  @default(true) @map("security_alerts")
  weeklySummary  Boolean  @default(false) @map("weekly_summary")
  productUpdates Boolean  @default(false) @map("product_updates")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("admin_notification_settings")
}

model AdminSecuritySettings {
  id             String   @id @default(uuid())
  userId         Int      @unique @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  twoFactorAuth  Boolean  @default(false) @map("two_factor_auth")
  publicProfile  Boolean  @default(true) @map("public_profile")
  dataSharing    Boolean  @default(true) @map("data_sharing")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("admin_security_settings")
}

model AdminTeamMember {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  role        String   @default("Member")
  status      String   @default("active")
  invitedById Int      @map("invited_by_id")
  invitedBy   User     @relation(fields: [invitedById], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("admin_team_members")
}

model AdminPreferences {
  id         String   @id @default(uuid())
  userId     Int      @unique @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme      String   @default("light")
  language   String   @default("en")
  timezone   String   @default("UTC")
  dateFormat String   @default("YYYY-MM-DD") @map("date_format")
  timeFormat String   @default("24h") @map("time_format")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("admin_preferences")
}

model Template {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  category  String
  content   String
  isPremium Boolean  @default(false)

  @@map("templates")
}
